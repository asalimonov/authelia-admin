{
  "name": "svelte-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host --port 9093",
    "build": "vite build",
    "preview": "HOST=0.0.0.0 PORT=9093 node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:functional": "vitest run --config vitest.functional.config.ts",
    "lint": "eslint 'src/**/*.{ts,svelte}'",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/ldapjs": "^3.0.6",
    "@types/pg": "^8.16.0",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "serve": "^14.2.5",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@inlang/paraglide-js": "^2.13.2",
    "cross-fetch": "^4.1.0",
    "encoding": "^0.1.13",
    "graphql": "^16.13.1",
    "ldapts": "^8.1.7",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.7",
    "yaml": "^2.8.2"
  }
}
